        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"neon-drift-boss.apk\""
        },
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Cache-Control",
